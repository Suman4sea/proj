---
import Navbar from '../components/navbar.tsx'
import Footer from '../components/footer.tsx'

export interface LayoutProps {
  title : string 
}

const { title } = Astro.props as LayoutProps
---


<html lang="en">
  <head>
    <meta charset="utf-8" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=5.0, user-scalable=yes" />
		<meta name="description" content="Interior Design Website Template" />
    <meta title = {title}/>
    <meta name="theme-color" content="#3D3D3D" />
    <meta name="apple-mobile-web-app-capable" content="yes" />
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent" />

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=Jost:ital,wght@0,100;0,200;0,300;0,400;0,500;0,600;0,700;0,800;0,900;1,100;1,200;1,300;1,400;1,500;1,600;1,700;1,800;1,900&display=swap" rel="stylesheet">
    
    <title>{title}</title>
    <style>
      * {
        touch-action: manipulation;
      }

      html, body {
        font-size: clamp(14px, 2.5vw, 16px);
      }

      button {
        transition: all 300ms ease-in-out;
        min-height: 44px;
        min-width: 44px;
      }
      
      button:hover {
        background-color: #D3D3D3 !important;
        transform: translateY(-3px);
        box-shadow: 0 10px 25px rgba(45, 47, 54, 0.3);
      }
      
      button:active {
        transform: translateY(-1px);
      }

      @media (max-width: 640px) {
        button {
          font-size: 14px;
          padding: 12px 20px;
        }
      }
    </style>
  </head>
  <body>
    <main class='bg-main bg-no-repeat bg-cover bg-center'>
      <Navbar client:load/>
      <slot/>
      <!-- All different pages to be rendered here -->
      <Footer />
    </main>
  </body>
</html>


